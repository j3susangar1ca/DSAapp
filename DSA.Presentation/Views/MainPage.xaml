<Page
    x:Class="DSA.Presentation.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="using:DSA.Domain.Entities"
    xmlns:converters="using:DSA.Presentation.Converters"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,0,0,20">
            <TextBlock Text="Bandeja de Entrada Operativa" Style="{StaticResource TitleTextBlockStyle}"/>
            <Button Command="{x:Bind ViewModel.RefreshBandejaCommand}" Content="Actualizar">
                <Button.Icon>
                    <SymbolIcon Symbol="Refresh"/>
                </Button.Icon>
            </Button>
        </StackPanel>

        <ListView Grid.Row="1" 
                  ItemsSource="{x:Bind ViewModel.BandejaEntrada, Mode=OneWay}"
                  SelectedItem="{x:Bind ViewModel.DocumentoSeleccionado, Mode=TwoWay}"
                  SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="d:Documento">
                    <Grid Padding="12">
                        <StackPanel>
                            <TextBlock Text="{x:Bind Nombre}" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="{x:Bind Id}" FontSize="12" Foreground="Gray"/>
                                <Border Background="Red" CornerRadius="4" Padding="4,2" 
                                        Visibility="{x:Bind IsUrgent, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="URGENTE" FontSize="10" Foreground="White"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
