<Page
    x:Class="DSA.Presentation.Views.CapturaView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <StackPanel Spacing="16" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Ellipse Width="48" Height="48" Fill="{x:Bind ViewModel.SlaColorBrush, Mode=OneWay}" 
                 Stroke="DarkGray" StrokeThickness="2" />
        
        <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" 
                   Style="{StaticResource SubtitleTextBlockStyle}" 
                   TextAlignment="Center" />

        <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" 
                      Width="64" Height="64" Margin="0,20,0,0"/>

        <Button Content="Iniciar Captura" 
                Command="{x:Bind ViewModel.EjecutarCapturaCommand}" 
                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InvertedBoolConverter}}"
                Style="{StaticResource AccentButtonStyle}" 
                HorizontalAlignment="Center" />
    </StackPanel>
</Page>