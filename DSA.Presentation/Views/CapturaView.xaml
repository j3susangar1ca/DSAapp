<Page
    x:Class="DSA.Presentation.Views.CapturaView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:DSA.Presentation.Converters"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <StackPanel Spacing="16" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center">

        <Ellipse Width="48" Height="48"
                 Fill="CornflowerBlue"
                 Stroke="DarkGray" StrokeThickness="2" />

        <TextBlock Text="{x:Bind ViewModel.MensajeEstado, Mode=OneWay}"
                   Style="{StaticResource SubtitleTextBlockStyle}"
                   TextAlignment="Center" />

        <ProgressBar Value="{x:Bind ViewModel.Porcentaje, Mode=OneWay}"
                     Minimum="0" Maximum="100"
                     Width="300" />

        <TextBlock Text="{x:Bind ViewModel.FaseActual, Mode=OneWay}"
                   FontSize="12"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   TextAlignment="Center" />

        <ProgressRing IsActive="{x:Bind ViewModel.EstaEscaneando, Mode=OneWay}"
                      Width="64" Height="64" Margin="0,20,0,0"/>

        <Button Content="Iniciar Captura"
                Command="{x:Bind ViewModel.IniciarDigitalizacionCommand}"
                CommandParameter="{x:Null}"
                IsEnabled="{x:Bind ViewModel.EstaEscaneando, Mode=OneWay,
                            Converter={StaticResource InvertedBoolConverter}}"
                Style="{StaticResource AccentButtonStyle}"
                HorizontalAlignment="Center" />

        <Button Content="Cancelar"
                Command="{x:Bind ViewModel.CancelarDigitalizacionCommand}"
                Visibility="{x:Bind ViewModel.EstaEscaneando, Mode=OneWay,
                             Converter={StaticResource BoolToVis}}"
                HorizontalAlignment="Center" />

        <StackPanel Spacing="8"
                    Visibility="{x:Bind ViewModel.Exitoso, Mode=OneWay,
                                 Converter={StaticResource BoolToVis}}">
            <InfoBar IsOpen="True" Severity="Success"
                     Title="Digitalización Completada"
                     Message="{x:Bind ViewModel.MensajeEstado, Mode=OneWay}" />
            <TextBlock FontSize="11"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind ViewModel.HashResultado, Mode=OneWay}" />
        </StackPanel>

    </StackPanel>
</Page>