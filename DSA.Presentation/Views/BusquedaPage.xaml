<Page
    x:Class="DSA.Presentation.Views.BusquedaPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="using:DSA.Domain.Entities"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    xmlns:core="using:Microsoft.Xaml.Interactions.Core"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <Grid Padding="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Búsqueda Avanzada de Acervo" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,16"/>

        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <AutoSuggestBox QueryIcon="Find" 
                            PlaceholderText="Buscar por nombre, folio, remitente o contenido OCR..."
                            Text="{x:Bind ViewModel.QueryBusqueda, Mode=TwoWay}"
                            Margin="0,0,16,0" VerticalAlignment="Center">
                <interactivity:Interaction.Behaviors>
                    <core:EventTriggerBehavior EventName="QuerySubmitted">
                        <core:InvokeCommandAction Command="{x:Bind ViewModel.BuscarDocumentosCommand}" />
                    </core:EventTriggerBehavior>
                </interactivity:Interaction.Behaviors>
            </AutoSuggestBox>

            <ProgressRing Grid.Column="1" IsActive="{x:Bind ViewModel.IsSearching, Mode=OneWay}" 
                          Width="32" Height="32" VerticalAlignment="Center"/>
        </Grid>

        <ListView Grid.Row="2" ItemsSource="{x:Bind ViewModel.Resultados, Mode=OneWay}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="d:Documento">
                    <Grid Padding="12" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="{x:Bind Nombre}" FontWeight="SemiBold" FontSize="16"/>
                            <TextBlock Text="{x:Bind Id}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock Text="📁 ARCHIVADO" Foreground="Green" FontSize="11" 
                                       Visibility="{x:Bind IsArchivado, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
